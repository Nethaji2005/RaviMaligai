# ============ IMPORTANT ============
# This is a TEMPLATE file. Copy to .env.development and .env.production
# DO NOT commit .env files to git (they're in .gitignore)
# ===================================

# LOCAL DEVELOPMENT
# Used when running: npm run dev
# Backend should be running on http://localhost:4000
VITE_API_URL=http://localhost:4000

# PRODUCTION (Render/Netlify)
# Used during build and production
# Replace with your actual deployed backend URL
# Example: https://ravi-maligai.onrender.com
# VITE_API_URL=https://your-backend-url.com
