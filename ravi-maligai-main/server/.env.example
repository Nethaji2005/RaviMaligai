# MongoDB Connection URI
# Local: mongodb://localhost:27017/grocery-ims
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/database-name
MONGO_URI=mongodb://localhost:27017/grocery-ims

# Server Port
PORT=4000

# Node Environment
NODE_ENV=development

# Frontend URL (for CORS configuration)
# Local: Leave empty (defaults to http://localhost:3000)
# Production: https://your-frontend-domain.com
FRONTEND_URL=
